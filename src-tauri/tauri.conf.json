{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Input",
  "version": "0.1.0",
  "identifier": "com.voiceinput.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node /Users/advance/Documents/voice-input-mac/scripts/dev-frontend.mjs",
    "beforeBuildCommand": "node /Users/advance/Documents/voice-input-mac/scripts/build-frontend.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Voice Input",
        "label": "main",
        "width": 392,
        "height": 560,
        "resizable": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "skipTaskbar": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
